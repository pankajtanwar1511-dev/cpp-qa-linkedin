# LinkedIn API Credentials
# Copy this file to .env and add your credentials

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_USER_ID=urn:li:person:YOUR_PERSON_ID_HERE

# How to get credentials:
# 1. Create LinkedIn Developer App at https://www.linkedin.com/developers/
# 2. Get OAuth 2.0 access token with 'w_member_social' scope
# 3. Get your person URN from API response
